# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds

# Project-specific: raw data and legacy files (too large / not reproducibility-critical)
Data/
Papers/
Old\ Attempts\ and\ Results/
Data\ Request\ Background\ Files/

# Generated self-contained print HTML (rebuilt by analysis/08_build_pdf.py)
manuscript/main_print.html

# Python cache
analysis/__pycache__/
output/.mpl/


