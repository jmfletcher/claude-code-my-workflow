# ==============================================================================
# .gitignore — Panel Conditioning (UK cohorts)
# ==============================================================================

# ------------------------------------------------------------------------------
# Raw data — NOT tracked (large files; see DATA.md for download instructions)
# ------------------------------------------------------------------------------
Data/

# Legacy partial analyses — large and not part of current pipeline
Old Attempts and Results/

# IRB forms and data request documents — sensitive, not for public repo
Data Request Background Files/

# Reference papers — copyrighted PDFs, not redistributable
Papers/

# ------------------------------------------------------------------------------
# LaTeX build artifacts
# ------------------------------------------------------------------------------
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Track manuscript PDF (pre-built for readers who cannot render Quarto)
# *.pdf is NOT ignored so that manuscript/main.pdf is committed

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# ------------------------------------------------------------------------------
# R (not used in current pipeline; kept for safety)
# ------------------------------------------------------------------------------
.Rproj.user/
.Rhistory
.RData
.Rdata

# ------------------------------------------------------------------------------
# OS / editor files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# Claude Code local / machine-specific files
# ------------------------------------------------------------------------------
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# ------------------------------------------------------------------------------
# Quarto rendering artifacts
# ------------------------------------------------------------------------------
/.quarto/
**/.quarto/
manuscript/main_files/
manuscript/main.html
manuscript/output/
Slides/main.html
output/.mpl/


